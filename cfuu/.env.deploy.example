# Copy this file to .env.deploy and fill in your server info.
# Do not commit .env.deploy.

DEPLOY_HOST=example.com
DEPLOY_USER=root
DEPLOY_PORT=22
DEPLOY_REMOTE_DIR=/var/www/cfuu

# Optional: private key path. Leave empty to use your default ssh agent/config.
# Windows example: C:\Users\Admin\.ssh\id_rsa
# Linux/macOS example: /home/me/.ssh/id_rsa
DEPLOY_SSH_KEY=

# Optional: extra ssh/scp args, for example:
# DEPLOY_SSH_EXTRA_ARGS=-o StrictHostKeyChecking=accept-new
DEPLOY_SSH_EXTRA_ARGS=

# Optional: set to 1 to keep the local .deploy/*.tar.gz archive after upload.
DEPLOY_KEEP_ARCHIVE=0
